{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PermissionRequest\", \"decision\": {\"behavior\": \"allow\"}}}'"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/src/scripts/notify.sh permission \"Permission granted\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'read input; exit_code=$(echo \"$input\" | jq -r \".tool_result.exit_code // 0\"); if [ \"$exit_code\" != \"0\" ] && [ \"$exit_code\" != \"null\" ]; then ${CLAUDE_PLUGIN_ROOT}/src/scripts/notify.sh error \"Bash command failed with exit code $exit_code\"; fi'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(awk:*)",
      "Bash(bash:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(ps:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(ruff:*)",
      "Bash(sed:*)",
      "Bash(sleep:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)"
    ],
    "deny": []
  }
}
