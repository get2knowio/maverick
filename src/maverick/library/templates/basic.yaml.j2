version: "1.0"
name: {{ name }}
description: "{{ description if description else 'TODO - Describe what this workflow does' }}"

# ------------------------------------------------------------------------------
# Input Declarations
# ------------------------------------------------------------------------------
inputs:
  example_input:
    type: string
    required: true
    description: Example input parameter - replace with your actual inputs

# ------------------------------------------------------------------------------
# Workflow Steps
# ------------------------------------------------------------------------------
steps:
  # Step 1: Initialize
  - name: init
    type: python
    action: example_init_action
    kwargs:
      input_value: ${{ '{{ inputs.example_input }}' }}

  # Step 2: Main processing
  - name: main
    type: python
    action: example_main_action
    kwargs:
      init_result: ${{ '{{ steps.init.output }}' }}

  # Step 3: Cleanup
  - name: cleanup
    type: python
    action: example_cleanup_action
    kwargs:
      main_result: ${{ '{{ steps.main.output }}' }}
