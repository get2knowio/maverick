from __future__ import annotations

from typing import Any

from maverick.workflows.base import PythonWorkflow


class {{ name.replace('-', '_').title().replace('_', '') }}Workflow(PythonWorkflow):
    """{{ description if description else 'Workflow demonstrating loop step execution' }}."""

    async def _run(self, inputs: dict[str, Any]) -> Any:
        """Execute workflow steps with loop processing.

        Args:
            inputs: Workflow input parameters.

        Returns:
            Final output dict.
        """
        items = inputs.get("items", [])

        # Process each item
        results = []
        for i, item in enumerate(items):
            step_name = f"process_{i}"
            await self.emit_step_started(step_name)
            try:
                result = await process_item(item=item)
            except Exception as exc:
                await self.emit_step_failed(step_name, str(exc))
                raise
            await self.emit_step_completed(step_name, output=result)
            results.append(result)

        # Combine results
        await self.emit_step_started("combine_results")
        try:
            combined = await combine_results(results=results)
        except Exception as exc:
            await self.emit_step_failed("combine_results", str(exc))
            raise
        await self.emit_step_completed("combine_results", output=combined)

        return combined


async def process_item(item: object) -> str:
    """Process a single item."""
    return f"Processed: {item}"


async def combine_results(results: list) -> dict:
    """Combine all results."""
    return {"success": True, "results": results}
